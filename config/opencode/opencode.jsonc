{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "system",
  "shell": "/bin/zsh",
  "agent": {
    "agent-tmux": {
      "description": "Manage tmux config in dotfiles worktree (branch: agent/tmux)",
      "prompt": "agents/agent-tmux.md",
      "mode": "subagent"
    },
    "agent-opencode": {
      "description": "Manage opencode agent config in dotfiles worktree (branch: agent/opencode)",
      "prompt": "agents/agent-opencode.md",
      "mode": "subagent"
    },
    "agent-bootstrap": {
      "description": "Manage bootstrap scripts & Brewfile in dotfiles worktree (branch: agent/bootstrap)",
      "prompt": "agents/agent-bootstrap.md",
      "mode": "subagent"
    }
  },
  "permission": {
    "bash": {
      "*": "ask",
      "ls *": "allow",
      "pwd": "allow",
      "which *": "allow",
      "type *": "allow",
      "ps *": "allow",
      "df *": "allow",
      "du *": "allow",
      "cat *": "allow",
      "less *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "echo *": "allow",
      "env": "allow",
      "printenv *": "allow",
      "date": "allow",
      "cal": "allow",
      "uname *": "allow",
      "sysctl *": "allow",
      "sw_vers": "allow",
      "system_profiler *": "allow",
      "plutil *": "allow",
      "defaults read *": "allow",
      "cp *": "allow",
      "mv *": "allow",
      "mkdir *": "allow",
      "touch *": "allow",
      "ln *": "allow",
      "rmdir *": "allow",
      "rm *": "ask",
      "sudo *": "ask",
      "curl *": "allow",
      "wget *": "allow",
      "ping *": "allow",
      "dig *": "allow",
      "nslookup *": "allow",
      "ifconfig *": "allow",
      "netstat *": "allow",
      "lsof *": "allow",
      "brew *": "allow",
      "brew * *": "allow",
      "brew services *": "allow",
      "brew services * *": "allow",
      "npm *": "allow",
      "pip *": "allow",
      "pip3 *": "allow",
      "gem *": "allow",
      "cargo *": "allow",
      "git *": "allow",
      "make *": "allow",
      "node *": "allow",
      "python *": "allow",
      "python3 *": "allow",
      "ruby *": "allow",
      "go *": "allow",
      "rustc *": "allow",
      "swift *": "allow",
      "ditto *": "allow",
      "rsync *": "allow",
      "tar *": "allow",
      "gzip *": "allow",
      "unzip *": "allow",
      "diskutil list": "allow",
      "chmod *": "allow",
      "launchctl *": "ask",
      "diskutil *": "ask",
      "kill *": "ask",
      "killall *": "ask",
      "chown *": "ask",
      "ssh *": "ask",
      "scp *": "ask",
      "systemsetup *": "ask",
      "networksetup *": "ask",
      "scutil *": "ask",
      "opencode-memory *": "allow"
    },
    "edit": "allow",
    "external_directory": {
      "*": "ask",
      "~/*": "allow",
      "~/.config/**": "allow",
      "~/.aws/**": "allow",
      "~/.ssh/**": "allow",
      "~/.zsh*": "allow",
      "~/.zshenv*": "allow",
      "~/Projects/*": "allow",
      "~/Projects/**": "allow",
      "/etc/*": "allow",
      "/etc/**": "allow",
      "/usr/local/*": "allow",
      "/usr/local/**": "allow",
      "/Applications/*": "allow",
      "/Applications/**": "allow",
      "/Library/*": "allow",
      "/Library/**": "allow",
      "/opt/*": "allow",
      "/opt/**": "allow",
      "/tmp/*": "allow",
      "/tmp/**": "allow",
      "/private/etc/*": "allow",
      "/private/etc/**": "allow",
      "/var/log/*": "allow",
      "/var/log/**": "allow"
    }
  }
}
